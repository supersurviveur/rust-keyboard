{
  "crt-objects-fallback": "false",
  "arch": "avr",
  "atomic-cas": false,
  "cpu": "atmega32u4",
  "data-layout": "e-P1-p:16:8-i8:8-i16:8-i32:8-i64:8-f32:8-f64:8-n8:16-a:8",
  "eh-frame-header": false,
  "env": "",
  "exe-suffix": ".elf",
  "executables": true,
  "late-link-args": {
    "gcc": [
      "-lc",
      "-lgcc",
      "-flto"
    ],
    "gnu-lld-cc": [
      "-lc",
      "-lgcc",
      "-flto"
    ]
  },
  "max-atomic-width": 8,
  "linker": "avr-gcc",
  "linker-flavor": "gnu-cc",
  "linker-is-gnu": true,
  "llvm-target": "avr-none-none",
  "os": "none",
  "pre-link-args": {
    "gcc": [
      "-mmcu=atmega32u4",
      "-Wl,--as-needed"
    ]
  },
  "target-c-int-width": 16,
  "target-endian": "little",
  "target-pointer-width": 16,
  "vendor": "unknown",
  "relocation-model": "static"
}
